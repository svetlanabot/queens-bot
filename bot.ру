async def text_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    step = context.user_data.get("step")

    if step == "fio":
        context.user_data["fio"] = update.message.text
        context.user_data["step"] = "phone"
        await update.message.reply_text("Введите номер телефона:")
        return

    if step == "phone":
        context.user_data["phone"] = update.message.text
        context.user_data["step"] = "city"
        await update.message.reply_text("Введите ваш город:")
        return

    if step == "city":
        context.user_data["city"] = update.message.text
        context.user_data["step"] = "email"
        await update.message.reply_text("Введите вашу электронную почту:")
        return

    if step == "email":
        context.user_data["email"] = update.message.text

        model = context.user_data.get("model", "не указана")
        amount = context.user_data.get("amount", "не указана")
        payment_id = context.user_data.get("payment_id", "не указан")

        fio = context.user_data.get("fio")
        phone = context.user_data.get("phone")
        city = context.user_data.get("city")
        email = context.user_data.get("email")

        user = update.effective_user
        username = user.username if user.username else "без username"

        await update.message.reply_text(
            "Спасибо за ваш заказ.\n\n"
            "Ожидайте, с вами свяжутся.\n\n"
            "Если остались вопросы — свяжитесь с нашим менеджером.",
            reply_markup=manager_keyboard()
        )

        await safe_admin_message(
            context,
            "НОВАЯ ЗАЯВКА ПОСЛЕ ОПЛАТЫ\n\n"
            f"Модель: {model}\n"
            f"Сумма: {amount} ₽\n\n"
            f"ФИО: {fio}\n"
            f"Телефон: {phone}\n"
            f"Город: {city}\n"
            f"Email: {email}\n\n"
            f"Пользователь: @{username}\n"
            f"Telegram ID: {user.id}\n"
            f"Payment ID: {payment_id}"
        )

        context.user_data.clear()


